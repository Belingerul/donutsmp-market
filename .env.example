# Telegram
TELEGRAM_BOT_TOKEN=your_botfather_token_here
ADMIN_TELEGRAM_ID=your_telegram_id_here

# Mini App public URL (ngrok / Cloudflare Tunnel / VPS IP)
WEBAPP_URL=https://your-url-here.trycloudflare.com

# Minecraft bot account
MC_USERNAME=yourbotaccount@email.com
MC_SERVER=donutsmp.net
MC_PORT=25565
MC_VERSION=1.20.6
MC_HOME_CMD=/home 1

# Pricing (in USD)
PRICE_SPAWNER=0.16
PRICE_1M_COINS=0.037

# Withdrawal settings
MIN_WITHDRAW=0
WITHDRAW_HOLD_DAYS=0

# Solana wallet — export base58 private key from Phantom
SOLANA_PRIVATE_KEY=your_base58_private_key_here

# Optional: custom RPC for better reliability (Helius, QuickNode, etc.)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
